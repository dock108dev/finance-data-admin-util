# ============================================================================
# Fin Data Admin — Environment Variables
# ============================================================================
# Copy to .env and fill in values for your deployment.

# ── General ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/findata
DATABASE_URL_SYNC=postgresql://postgres:CHANGE_ME@postgres:5432/findata
POSTGRES_DB=findata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_PORT=6379

# ── API ────────────────────────────────────────────────────────────────────
API_KEY=CHANGE_ME_TO_SECURE_KEY
API_PORT=8000
API_URL=http://api:8000

# ── Web UI ─────────────────────────────────────────────────────────────────
WEB_PORT=3000

# ── OpenAI (narrative generation) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_ANALYSIS=gpt-4o
OPENAI_MODEL_CLASSIFICATION=gpt-4o-mini

# ── Data Source API Keys ───────────────────────────────────────────────────
# Stocks
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=

# Crypto
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=

# On-chain
ETHERSCAN_API_KEY=

# News
NEWS_API_KEY=

# Social (Reddit)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=fin-data-admin/1.0

# Social (X/Twitter)
X_AUTH_TOKEN=
X_CT0=

# Macro
FRED_API_KEY=

# ── Deploy (CI/CD secrets, not in .env) ────────────────────────────────────
# DEPLOY_HOST=
# DEPLOY_USER=
# DEPLOY_SSH_KEY=
# DEPLOY_PATH=

# =============================================================================
# Fin Data Admin — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Host Ports (mapped from Docker containers) ---
POSTGRES_PORT=5433
REDIS_PORT=6380
API_PORT=8001
WEB_PORT=3001

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/findata
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5433/findata

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6380/2
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# --- API Authentication ---
API_KEY=dev-key-do-not-use-in-production

# --- Stock Data Sources ---
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
# yfinance requires no API key

# --- Macro Economic Data ---
FRED_API_KEY=

# --- Crypto Data Sources ---
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=

# --- On-Chain ---
ETHERSCAN_API_KEY=

# --- Social / Sentiment ---
X_AUTH_TOKEN=
X_CT0=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=fin-data-admin/1.0

# --- News ---
NEWS_API_KEY=

# --- AI / ML ---
OPENAI_API_KEY=
OPENAI_MODEL_ANALYSIS=gpt-4o
OPENAI_MODEL_CLASSIFICATION=gpt-4o-mini

# --- Web UI ---
NEXT_PUBLIC_API_URL=http://localhost:8001
